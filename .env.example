# Gemini API Key
# Get your key from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Google Cloud Service Account JSON file path
# Download from: https://cloud.google.com/docs/authentication/getting-started
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json

# Google Drive folder IDs
# Input folder: where InBody PDF files are uploaded
DRIVE_INPUT_FOLDER_ID=your_input_folder_id_here

# Output folder: where processed PDFs are moved after processing
DRIVE_PROCESSED_FOLDER_ID=your_processed_folder_id_here

# Google Sheets for CSV data
# Spreadsheet ID: found in the URL of your Google Sheet (https://docs.google.com/spreadsheets/d/{SPREADSHEET_ID}/...)
GOOGLE_SHEETS_SPREADSHEET_ID=your_spreadsheet_id_here

# Sheet name within the spreadsheet (e.g., "InBodyData")
GOOGLE_SHEETS_SHEET_NAME=InBodyData
